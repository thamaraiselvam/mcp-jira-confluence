# ============================================================
# MCP Server for Jira & Confluence — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
#
# This server supports both Confluence and Jira with flexible
# credential configuration:
# 1. Common credentials: ATLASSIAN_* (shared by both services)
# 2. Service-specific: CONFLUENCE_* or JIRA_* (overrides common)
# ============================================================


# ============================================================
# ATLASSIAN — COMMON CREDENTIALS (RECOMMENDED)
# ============================================================

# ----------------------------------------------------------
# The base URL of your Atlassian instance.
# Used by both Confluence and Jira unless overridden.
# No trailing slash.
# Example: https://your-org.atlassian.net
# ----------------------------------------------------------
ATLASSIAN_URL=

# ----------------------------------------------------------
# The email address associated with your Atlassian account.
# Example: your.name@example.gov.sg
# ----------------------------------------------------------
ATLASSIAN_EMAIL=

# ----------------------------------------------------------
# An Atlassian API token generated from:
#   https://id.atlassian.com/manage-profile/security/api-tokens
#
# This token is used for both Confluence AND Jira unless you
# set separate CONFLUENCE_* or JIRA_* credentials below.
#
# Keep this value secret. Never commit it to version control.
# ----------------------------------------------------------
ATLASSIAN_API_TOKEN=


# ============================================================
# CONFLUENCE — SERVICE-SPECIFIC (OPTIONAL)
# ============================================================
# Override common ATLASSIAN_* credentials for Confluence only.
# Use this if you need different credentials for Confluence.
# ----------------------------------------------------------

# Confluence-specific URL (overrides ATLASSIAN_URL)
# CONFLUENCE_URL=

# Confluence-specific email (overrides ATLASSIAN_EMAIL)
# CONFLUENCE_EMAIL=

# Confluence-specific API token (overrides ATLASSIAN_API_TOKEN)
# CONFLUENCE_API_TOKEN=

# ----------------------------------------------------------
# Confluence Space Key Scope (RECOMMENDED)
#
# When set, all Confluence searches are automatically scoped
# to this space (unless the CQL query already contains a
# space= clause), and any write operations (create, update,
# comment) targeting a page outside this space are rejected.
#
# Example: MYSPACE
# Default (when unset): all accessible spaces are in scope
# ----------------------------------------------------------
CONFLUENCE_SPACE_KEY=


# ============================================================
# JIRA — SERVICE-SPECIFIC (OPTIONAL)
# ============================================================
# Override common ATLASSIAN_* credentials for Jira only.
# Use this if you need different credentials for Jira.
# ----------------------------------------------------------

# Jira-specific URL (overrides ATLASSIAN_URL)
# JIRA_URL=

# Jira-specific email (overrides ATLASSIAN_EMAIL)
# JIRA_EMAIL=

# Jira-specific API token (overrides ATLASSIAN_API_TOKEN)
# JIRA_API_TOKEN=

# ----------------------------------------------------------
# Jira Project Key Scope (RECOMMENDED if using Jira tools)
#
# When set:
#   - JQL searches without an explicit project= clause are
#     automatically scoped to this project.
#   - Issue creation in any other project is rejected.
#
# Example: PROJ
# Default (when unset): all accessible projects are in scope
# ----------------------------------------------------------
JIRA_PROJECT_KEY=


# ============================================================
# TLS — OPTIONAL
# ============================================================

# ----------------------------------------------------------
# Bypass TLS Certificate Verification
#
# Set to "true" or "1" to disable TLS certificate checks.
# Required when the server sits behind a Cloudflare VPN or
# a corporate proxy that performs TLS inspection / re-signing.
#
# This flag applies to BOTH Confluence and Jira clients.
#
# WARNING: Only enable this in trusted network environments.
#          Do NOT enable in production without understanding
#          the security implications.
#
# Accepted truthy values : true, 1
# Default (when unset)   : false  (TLS verification enabled)
# ----------------------------------------------------------
IGNORE_TLS_ERRORS=false


# ============================================================
# SERVER — OPTIONAL
# ============================================================

# ----------------------------------------------------------
# HTTP Server Port
#
# The port the MCP server listens on.
# The server always binds to 127.0.0.1 (localhost only).
#
# Default: 3000
# ----------------------------------------------------------
MCP_PORT=3000

# ----------------------------------------------------------
# Verbose Mode (Debug Logging)
#
# Set to "true" or "1" to enable detailed debug logging.
# Logs include:
#   - Configuration loading
#   - HTTP requests and responses
#   - MCP request/response payloads
#   - Connection lifecycle events
#
# Default: false (disabled)
# ----------------------------------------------------------
VERBOSE=false
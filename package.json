{
  "name": "mcp-jira-confluence",
  "version": "1.0.2",
  "description": "MCP server for Jira and Confluence with search, view, create, and edit capabilities. Converts Markdown to ADF for beautiful native formatting.",
  "type": "module",
  "bin": {
    "mcp-jira-confluence": "dist/index.js"
  },
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "dev:http": "tsc && MCP_PORT=9339 node dist/index.js",
    "dev:verbose": "tsc && VERBOSE=true node dist/index.js",
    "prepack": "npm run build",
    "pack:check": "npm pack --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "validate": "tsc && node dist/validate.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "axios": "^1.9.0",
    "dotenv": "^16.5.0",
    "markdown-it": "^14.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.21",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "jira",
    "confluence",
    "atlassian",
    "ai",
    "copilot",
    "opencode",
    "claude",
    "adf",
    "markdown"
  ],
  "author": "Thamaraiselvam T",
  "repository": {
    "type": "git",
    "url": "https://github.com/thamaraiselvam/mcp-jira-confluence"
  },
  "bugs": {
    "url": "https://github.com/thamaraiselvam/mcp-jira-confluence/issues"
  },
  "homepage": "https://github.com/thamaraiselvam/mcp-jira-confluence#readme",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
